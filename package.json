{
  "name": "postgres-ssh-mcp",
  "version": "0.0.0",
  "description": "MCP server for Postgres (with SSH tunnel support)",
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "claude",
    "postgres",
    "ssh"
  ],
  "author": "SecretX33",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SecretX33/postgres-ssh-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SecretX33/postgres-ssh-mcp/issues"
  },
  "homepage": "https://github.com/SecretX33/postgres-ssh-mcp#readme",
  "bin": {
    "postgres-ssh-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "dev": "dotenv -v NODE_ENV=development -- nodemon --watch src --watch .env --ext ts --exec \"tsc && node dist/server.js\"",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check --cache src",
    "format:write": "prettier --write --cache src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@pgsql/traverse": "17.2.4",
    "dotenv": "17.3.1",
    "pg": "8.20.0",
    "pgsql-parser": "17.9.12",
    "tunnel-ssh": "5.2.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@types/pg": "8.18.0",
    "@types/ssh2": "1.15.5",
    "dotenv-cli": "11.0.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
